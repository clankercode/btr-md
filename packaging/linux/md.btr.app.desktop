[Desktop Entry]
Type=Application
Name=btr.md
GenericName=Markdown Editor
Comment=better markdown — fast, secure markdown editor for Linux
Exec=btr-md %F
Icon=md.btr.app
Terminal=false
Categories=Utility;TextEditor;
MimeType=text/markdown;text/x-markdown;
StartupNotify=true
# Must match the window's runtime WM_CLASS / Wayland app-id. Tauri leaves
# enableGTKAppId off (multi-process, one window per file — see btr-md.1), so the
# GTK app-id is unset and the class falls back to the binary name (btr-md), not
# the identifier. KDE matches this to the entry, then uses Icon= below.
StartupWMClass=btr-md
Actions=NewWindow;OpenFile;

[Desktop Action NewWindow]
Name=New Window
Exec=btr-md

[Desktop Action OpenFile]
Name=Open File...
Exec=btr-md --open-dialog
