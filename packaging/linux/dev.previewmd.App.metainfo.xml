<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>dev.previewmd.App</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>
  <name>preview-md</name>
  <summary>Best-in-class markdown preview for Linux</summary>
  <description>
    <p>preview-md is a fast, feature-rich markdown previewer built with Tauri. It offers:</p>
    <ul>
      <li>Live preview with split or unified view</li>
      <li>Multiple bundled themes with WCAG-compliant color choices</li>
      <li>Syntax highlighting for code blocks</li>
      <li>Mermaid diagram rendering</li>
      <li>KaTeX math support</li>
      <li>Keyboard-driven workflow</li>
    </ul>
  </description>
  <launchable type="desktop-id">dev.previewmd.App.desktop</launchable>
  <screenshots>
    <screenshot type="default">
      <caption>Main preview window with the welcome screen and theme-aware chrome</caption>
      <image type="source">https://preview-md.example.com/screenshots/welcome.png</image>
    </screenshot>
  </screenshots>
  <url type="homepage">https://github.com/preview-md/preview-md</url>
  <provides>
    <binary>preview-md</binary>
  </provides>
  <releases>
    <release version="0.1.0" date="2026-05-24">
      <description>
        <p>Initial release with theme picker, Mermaid support, and KaTeX math.</p>
      </description>
    </release>
  </releases>
  <categories>
    <category>Utility</category>
    <category>TextEditor</category>
  </categories>
  <keywords>
    <keyword>markdown</keyword>
    <keyword>preview</keyword>
    <keyword>previewer</keyword>
  </keywords>
</component>
