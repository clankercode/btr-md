{
  "//": "SCOPED typecheck. The runtime build is esbuild-only and the legacy UI",
  "//2": "modules use untyped vendor imports + `as any`. This config deliberately",
  "//3": "type-checks ONLY the new lifecycle/tab/pure-logic modules so the",
  "//4": "discriminated-union + assertNever guarantees are compile-verified.",
  "//5": "Add new modules to `include` as they are written; do NOT glob src/.",
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "types": []
  },
  "include": [
    "src/backend/commands.ts",
    "src/backend/invoke.ts",
    "src/backend/files.ts",
    "src/backend/settings.ts",
    "src/backend/theme.ts",
    "src/backend/docs.ts",
    "src/backend/windows.ts",
    "src/debounce.ts",
    "src/editor_insert.ts",
    "src/doc_state.ts",
    "src/tabs.ts",
    "src/tabbar.ts",
    "src/file_browser.ts",
    "src/settings_menu.ts",
    "src/counts.ts",
    "src/footnotes.ts",
    "src/table_copy.ts",
    "src/insert_menu.ts",
    "src/link_activation.ts",
    "src/document_contracts.ts",
    "src/document_facts_store.ts",
    "src/diagnostics.ts",
    "src/diagnostics_panel.ts",
    "src/inline_issues.ts",
    "src/resource_policy.ts",
    "src/trust_policy_panel.ts",
    "src/local_asset_grants.ts",
    "src/trust_roots.ts",
    "src/outline_panel.ts",
    "src/actions.ts",
    "src/keybindings.ts",
    "src/command_overlay.ts",
    "src/shortcut_editor.ts",
    "src/context_menu.ts",
    "src/find_query.ts",
    "src/find_preview.ts",
    "src/frontmatter_edit.ts",
    "src/frontmatter_panel.ts",
    "src/stats_popover.ts",
    "src/editor_format.ts",
    "src/editor_list.ts",
    "src/find_replace.ts",
    "src/export_document.ts",
    "src/image_embed.ts",
    "src/scroll_sync.ts",
    "src/scroll_mirror.ts",
    "src/scroll_pure.ts",
    "src/confirm_close_dialog.ts"
  ]
}
